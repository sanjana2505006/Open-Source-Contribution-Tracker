# API
PORT=4000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:4000

# PostgreSQL
# Homebrew Postgres default: postgresql://YOUR_MAC_USERNAME@localhost:5432/osct
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/osct

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Generate with: openssl rand -base64 32
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=30

# Comma-separated GitHub usernames who can open /admin (e.g. your username)
ADMIN_USERNAMES=

# OSCT Agent — pick one provider (Groq recommended; generous free tier)
# Get a free Groq key: https://console.groq.com/keys
AGENT_PROVIDER=groq
GROQ_API_KEY=
# Or OpenAI: https://platform.openai.com/api-keys
# AGENT_PROVIDER=openai
# OPENAI_API_KEY=
# Or Gemini: https://aistudio.google.com/apikey
# AGENT_PROVIDER=gemini
# GEMINI_API_KEY=
AGENT_MODEL=llama-3.3-70b-versatile
# Set to false to disable the agent
# AGENT_ENABLED=false
AGENT_RATE_LIMIT_PER_HOUR=30

# Weekly stuck-issue digest email (optional — Resend)
# 1. Sign up: https://resend.com
# 2. Create API key: https://resend.com/api-keys → paste below
# 3. Testing (no domain): use onboarding@resend.dev — only delivers to your Resend account email
# 4. Production: verify a domain in Resend, then set DIGEST_FROM_EMAIL e.g. "OSCT <digest@yourdomain.com>"
# 5. Generate cron secret: openssl rand -base64 32
RESEND_API_KEY=
DIGEST_FROM_EMAIL="OSCT <onboarding@resend.dev>"
CRON_SECRET=
